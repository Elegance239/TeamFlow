<h2>Hi <%= @assignee.name %>,</h2>

<p>This is a reminder that the following task is <strong>due tomorrow</strong>.</p>

<table>
  <tr>
    <td><strong>Task:</strong></td>
    <td><%= @task.description %></td>
  </tr>
  <tr>
    <td><strong>Due Date:</strong></td>
    <td><%= @task.due_date.strftime("%B %d, %Y") %></td>
  </tr>
  <tr>
    <td><strong>Points:</strong></td>
    <td><%= @task.points %></td>
  </tr>
  <tr>
    <td><strong>Current State:</strong></td>
    <td><%= @task.current_state %></td>
  </tr>
</table>

<p>Please log in to TeamFlow to complete your task before the deadline.</p>